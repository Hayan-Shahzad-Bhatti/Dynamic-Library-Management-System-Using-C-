    }

    bookFile.close();

    // Save Members
    ofstream memberFile("Members.txt");

    memberFile << total_members << endl;

    for(int i = 0; i < total_members; i++)
    {
        memberFile << members[i].id << endl;
        memberFile << members[i].name << endl;
        memberFile << members[i].borrowedISBN << endl;
    }

    memberFile.close();

    cout << "Data Saved Successfully!" << endl;
}
void loadData()
{
    // ---------- Load Books ----------
    ifstream BookFile("Books.txt");

    if(BookFile)
    {
        BookFile >> total_books;
        BookFile.ignore();

        while(total_books > max_books)
        {
            resizeBooks();
        }

        for(int i = 0; i < total_books; i++)
        {
            BookFile >> books[i].id;
            BookFile.ignore();

            BookFile.getline(books[i].title, 50);
            BookFile.getline(books[i].author, 50);
            BookFile.getline(books[i].ISBN, 20);

            BookFile >> books[i].copies;
            BookFile.ignore();
        }

        BookFile.close();
    }

    // ---------- Load Members ----------
    ifstream MemberFile("Members.txt");

    if(MemberFile)
    {
        MemberFile >> total_members;
        MemberFile.ignore();

        while(total_members > max_members)
        {
            resizeMembers();
        }

        for(int i = 0; i < total_members; i++)
        {
            MemberFile >> members[i].id;
            MemberFile.ignore();

            MemberFile.getline(members[i].name, 50);
            MemberFile.getline(members[i].borrowedISBN, 20);
        }

        MemberFile.close();
    }
}
void total(){
    cout<<"Total Members: "<<total_members<<endl;
    cout<<"Total Books: "<<total_books<<endl;
}
